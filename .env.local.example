# API NestJS v3 (couche lib/api). Inclut le préfixe global /api/v1.
NEXT_PUBLIC_API_URL=https://api.primal.tg/api/v1
NEXT_PUBLIC_SITE_URL=https://app.primal.net/api/v1



# WhatsApp public (site client — hero, footer, contact)
NEXT_PUBLIC_WHATSAPP_NUMBER=22893378344

# Email affiché sur la page Contact
NEXT_PUBLIC_CONTACT_EMAIL=contact@primalstore.tg

# CallMeBot WhatsApp — alerte simple uniquement (ex: "Salim a commandé un produit")
# https://www.callmebot.com/blog/free-api-whatsapp-messages/
CALLMEBOT_PHONE=+228XXXXXXXX
CALLMEBOT_APIKEY=votre_apikey

# Resend — email avec tous les détails de la commande
# https://resend.com
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=PrimalStore <onboarding@resend.dev>
RESEND_TO_EMAIL=votre-email@example.com
